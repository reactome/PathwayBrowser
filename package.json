{
  "name": "pathway-browser",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "run-p dev:* && wait-on dist/reactome-cytoscape-style/index.scss && sleep 2 && ng serve --proxy-config proxy-gxa.conf.json",
    "dev:reactome-cytoscape-style": "ng build reactome-cytoscape-style --configuration development --watch &",
    "build:reactome-cytoscape-style": "ng build reactome-cytoscape-style",
    "test:reactome-cytoscape-style": "ng test reactome-cytoscape-style",
    "deploy:reactome-cytoscape-style": "ng build reactome-cytoscape-style; cd dist reactome-cytoscape-style; npm publish",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "page": "ng build --base-href=/PathwayBrowser/ --configuration development; ng deploy --no-build",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.1.2",
    "@angular/cdk": "^19.1.1",
    "@angular/common": "^19.1.2",
    "@angular/compiler": "^19.1.2",
    "@angular/core": "^19.1.2",
    "@angular/forms": "^19.1.2",
    "@angular/material": "^19.1.1",
    "@angular/platform-browser": "^19.1.2",
    "@angular/platform-browser-dynamic": "^19.1.2",
    "@angular/router": "^19.1.2",
    "@ngneat/until-destroy": "^10.0.0",
    "angular-split": "^17.2.0",
    "chroma-js": "^3.1.2",
    "cytoscape": "3.31.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-layers": "^3.0.0",
    "ngx-custom-material-file-input": "^19.0.0",
    "ngx-reactome-style": "file:.yalc/ngx-reactome-style",
    "@carrotsearch/foamtree": "3.5.4",
    "canvas-to-svg": "^1.0.3",
    "rxjs": "~7.8.0",
    "svg-pan-zoom": "^3.6.1",
    "tslib": "^2.3.0",
    "vectorious": "^6.1.12",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.1.3",
    "@angular/cli": "^19.1.3",
    "@angular/compiler-cli": "^19.1.2",
    "@angular/localize": "^19.1.2",
    "@types/chroma-js": "^3.1.1",
    "@types/cytoscape": "^3.21.9",
    "@types/cytoscape-fcose": "^2.2.4",
    "@types/jasmine": "~4.3.0",
    "@types/lodash": "^4.14.202",
    "angular-cli-ghpages": "^2.0.1",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^19.1.0",
    "npm-run-all": "^4.1.1",
    "typescript": "~5.7.3",
    "wait-on": "^8.0.1"
  }
}
